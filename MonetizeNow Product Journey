function tagColor(t){return t==='moat'?'var(--moat)':t==='diff'?'var(--diff)':'var(--ink4)'}
function tagBg(t){return t==='moat'?'var(--moat-bg)':t==='diff'?'var(--diff-bg)':'var(--core-bg)'}

function buildBlock(stage,container){
  var b=document.createElement('div');
  b.className='stage-block';
  if(stage.isMoat)b.style.borderColor='var(--moat-border)';
  // Label
  var lbl=document.createElement('div');
  lbl.className='stage-label';
  lbl.style.borderLeft='3px solid '+stage.color;
  lbl.innerHTML='<div class="stage-num">'+stage.num+'</div>'+
    '<div class="stage-title" style="color:'+stage.color+'">'+stage.title+'</div>'+
    (stage.isMoat?'<div class="moat-badge">◆ MOAT</div>':'')+
    '<div class="stage-count">'+stage.caps.length+' capabilities</div>';
  b.appendChild(lbl);
  // Break
  var brk=document.createElement('div');
  brk.className='stage-break';
  brk.innerHTML='<div class="break-eyebrow">The break</div><div class="break-text">'+stage.fracture+'</div>';
  b.appendChild(brk);
  // Caps
  var ca=document.createElement('div');
  ca.className='stage-caps';
  var grid=document.createElement('div');
  grid.className='caps-grid';
  stage.caps.forEach(function(cap,ci){
    var pid=stage.id+'-'+ci;
    var pill=document.createElement('div');
    pill.className='cap-pill';
    pill.id='pill-'+pid;
    pill.dataset.persona=cap.persona;
    var icon=cap.tag==='moat'?'◆':cap.tag==='diff'?'▲':'●';
    pill.innerHTML=
      '<div class="pill-icon" style="background:'+tagBg(cap.tag)+';color:'+tagColor(cap.tag)+'">'+icon+'</div>'+
      '<div class="pill-text"><div class="pill-name">'+cap.name+'</div><div class="pill-line">'+cap.line+'</div></div>'+
      '<div class="pill-dot" style="background:'+tagColor(cap.tag)+'"></div>';
    pill.onclick=function(){openDP(cap,pid,stage.color)};
    grid.appendChild(pill);
  });
  ca.appendChild(grid);
  b.appendChild(ca);
  container.appendChild(b);
}

function buildMap(containerId,stages){
  var el=document.getElementById(containerId);
  if(!el||el.children.length>0)return;
  stages.forEach(function(s){buildBlock(s,el)});
}

function buildOV(){
  var el=document.getElementById('ov-stages');
  D.forEach(function(s){
    var row=document.createElement('div');
    row.className='ov-row'+(s.isMoat?' moat':'');
    row.innerHTML='<div class="ov-num">'+s.num+'</div>'+
      '<div class="ov-name">'+s.title+'</div>'+
      '<div class="ov-break">'+s.fracture+'</div>'+
      '<div class="ov-pills">'+s.caps.slice(0,3).map(function(c){return'<span class="ov-pill">'+c.name+'</span>'}).join('')+(s.caps.length>3?'<span class="ov-pill">+'+( s.caps.length-3)+'</span>':'')+'</div>';
    row.onclick=function(){go(s.id,null)};
    el.appendChild(row);
  });
}

function openDP(cap,pid,color){
  document.querySelectorAll('.cap-pill').forEach(function(p){p.classList.remove('selected')});
  var pill=document.getElementById('pill-'+pid);
  if(pill)pill.classList.add('selected');
  document.getElementById('dp-title').textContent=cap.name;
  document.getElementById('dp-title').style.color=color||'var(--ink)';
  var pLabel=cap.persona==='revops'?'VP RevOps':cap.persona==='cfo'?'CFO · Finance':'Both personas';
  var pCls=cap.persona==='revops'?'chip-revops':cap.persona==='cfo'?'chip-cfo':'chip-both';
  var tLabel=cap.tag==='moat'?'Architectural moat':cap.tag==='diff'?'Differentiator':'Core';
  var tStyle=cap.tag==='moat'?'background:var(--moat-bg);color:var(--moat);border:1px solid var(--moat-border)':cap.tag==='diff'?'background:var(--diff-bg);color:var(--diff);border:1px solid var(--diff-border)':'background:var(--surface2);color:var(--ink2);border:1px solid var(--border2)';
  document.getElementById('dp-chips').innerHTML='<span class="dp-chip '+pCls+'">'+pLabel+'</span><span class="dp-chip" style="'+tStyle+'">'+tLabel+'</span>';
  var mk=function(items,color,lbl){
    return'<div class="dp-section"><div class="dp-sec-lbl" style="color:'+color+'"><span class="dot" style="background:'+color+'"></span>'+lbl+'</div><div class="dp-items">'+items.map(function(t){return'<div class="dp-item"><span class="dp-dash">—</span><span class="dp-text">'+t+'</span></div>'}).join('')+'</div></div>';
  };
  document.getElementById('dp-body').innerHTML=mk(cap.what,'var(--blue)','Behaviour')+mk(cap.prob,'var(--red)','Failure addressed')+mk(cap.feel,'var(--diff)','Who carries this today');
  document.getElementById('dp').classList.add('open');
  document.getElementById('sb-sel').textContent=cap.name;
}

function closeDP(){
  document.getElementById('dp').classList.remove('open');
  document.querySelectorAll('.cap-pill').forEach(function(p){p.classList.remove('selected')});
  document.getElementById('sb-sel').textContent='Select a capability for detail';
}

function toggleSB(){
  sbOpen=!sbOpen;
  document.getElementById('sidebar').classList.toggle('closed',!sbOpen);
}

var MAPS={'journey':'all','orig':'orig','cpq':'cpq','policy':'policy','contract':'contract','billing':'billing','infra':'infra'};

function go(id,el){
  document.querySelectorAll('.sec').forEach(function(s){s.classList.remove('on')});
  document.querySelectorAll('.sb-item').forEach(function(i){i.classList.remove('on')});
  var sec=document.getElementById('sec-'+id);
  if(sec)sec.classList.add('on');
  if(el)el.classList.add('on');
  else{document.querySelectorAll('.sb-item').forEach(function(i){if(i.getAttribute('onclick')&&i.getAttribute('onclick').indexOf("'"+id+"'")>-1)i.classList.add('on')})}
  if(id==='journey')buildMap('map-all',D);
  else if(MAPS[id]&&id!=='overview'){var s=D.find(function(x){return x.id===id});if(s)buildMap('map-'+id,[s]);}
  applyPersonaFilter();
}

function setP(p,btn){
  activeP=p;
  if(btn){document.querySelectorAll('.ptab').forEach(function(t){t.classList.remove('on')});btn.classList.add('on');}
  else{document.querySelectorAll('.ptab').forEach(function(t){t.classList.toggle('on',t.textContent.toLowerCase().replace(' ','')===p||(p==='all'&&t.textContent==='All'))})}
  document.getElementById('sb-p').innerHTML='Viewing: <span>'+(p==='all'?'All capabilities':p==='revops'?'VP RevOps view':'CFO view')+'</span>';
  applyPersonaFilter();
}

function applyPersonaFilter(){
  document.querySelectorAll('.cap-pill').forEach(function(pill){
    var pp=pill.dataset.persona;
    pill.classList.toggle('dimmed',activeP!=='all'&&pp!==activeP&&pp!=='both');
  });
}

buildOV();
