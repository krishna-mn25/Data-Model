<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MonetizeNow — Revenue Journey</title>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f8f7f4;--surface:#ffffff;--surface2:#f3f1ec;
  --border:rgba(0,0,0,0.07);--border2:rgba(0,0,0,0.13);
  --ink:#111110;--ink2:#484744;--ink3:#888680;--ink4:#b8b5ae;--ink5:#d8d5ce;
  --moat:#4338ca;--moat-bg:#eef2ff;--moat-border:#c7d2fe;
  --diff:#0d6b52;--diff-bg:#f0fdf9;--diff-border:#6ee7c7;
  --core-bg:#f8f7f4;--core-border:#d8d5ce;
  --red:#991b1b;--red-bg:#fff5f5;
  --green:#065f46;--green-bg:#f0fdf9;
  --blue:#1e40af;--blue-bg:#eff6ff;
}
html,body{height:100%;background:var(--bg);color:var(--ink);font-family:'Geist',sans-serif;font-size:13px;overflow:hidden}
.app{display:flex;flex-direction:column;height:100vh}
.topbar{height:50px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 24px;flex-shrink:0;gap:16px}
.t-left{display:flex;align-items:center;gap:12px}
.toggle-btn{width:28px;height:28px;border:1px solid var(--border2);border-radius:6px;background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .1s}
.toggle-btn:hover{background:var(--surface2)}
.hlines{width:14px;height:9px;display:flex;flex-direction:column;justify-content:space-between}
.hlines span{display:block;height:1.5px;background:var(--ink2);border-radius:1px}
.brand{font-family:'Instrument Serif',serif;font-size:15px;color:var(--ink);letter-spacing:-.01em}
.brand span{color:var(--ink4);font-size:13px;font-family:'Geist',sans-serif;font-weight:300}
.t-right{display:flex;align-items:center;gap:6px}
.ptab{padding:5px 13px;font-size:11px;font-weight:500;border:1px solid var(--border2);border-radius:20px;background:none;cursor:pointer;color:var(--ink3);font-family:'Geist',sans-serif;transition:all .12s}
.ptab:hover{color:var(--ink);border-color:var(--ink3)}
.ptab.on{background:var(--ink);color:#fff;border-color:var(--ink)}
.legend-bar{height:34px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 24px;gap:20px;flex-shrink:0}
.leg{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--ink3)}
.leg-mark{width:8px;height:8px;border-radius:2px;flex-shrink:0}
.leg-sep{width:1px;height:14px;background:var(--border2);margin:0 4px}
.main{flex:1;display:flex;overflow:hidden}
.sidebar{width:200px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;transition:width .2s cubic-bezier(.4,0,.2,1),opacity .15s}
.sidebar.closed{width:0;opacity:0;pointer-events:none;border-right:none}
.sb-scroll{flex:1;overflow-y:auto;padding:8px 0}
.sb-scroll::-webkit-scrollbar{width:3px}
.sb-scroll::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.sb-group{font-family:'Geist Mono',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink4);padding:12px 16px 4px}
.sb-item{display:flex;align-items:center;gap:8px;padding:7px 16px;font-size:12px;color:var(--ink3);cursor:pointer;border-left:2px solid transparent;transition:all .1s;white-space:nowrap;overflow:hidden}
.sb-item:hover{color:var(--ink);background:var(--surface2)}
.sb-item.on{color:var(--ink);background:var(--moat-bg);border-left-color:var(--moat);font-weight:500}
.sb-pip{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.content-area{flex:1;display:flex;overflow:hidden}
.content{flex:1;overflow-y:auto;padding:0}
.content::-webkit-scrollbar{width:4px}
.content::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.sec{display:none;padding:28px 32px 64px;animation:up .16s ease both}
.sec.on{display:block}
@keyframes up{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.journey-map{display:flex;flex-direction:column;gap:10px}
.stage-block{display:flex;border-radius:12px;overflow:hidden;border:1px solid var(--border);background:var(--surface);transition:border-color .15s}
.stage-block:hover{border-color:var(--border2)}
.stage-label{width:150px;flex-shrink:0;display:flex;flex-direction:column;justify-content:flex-start;padding:20px 16px;border-right:1px solid var(--border)}
.stage-num{font-family:'Geist Mono',monospace;font-size:9px;letter-spacing:.1em;color:var(--ink4);margin-bottom:6px}
.stage-title{font-family:'Instrument Serif',serif;font-size:15px;line-height:1.2;letter-spacing:-.01em;margin-bottom:8px}
.moat-badge{font-size:9px;font-family:'Geist Mono',monospace;letter-spacing:.07em;color:var(--moat);background:var(--moat-bg);padding:2px 6px;border-radius:3px;display:inline-block;margin-bottom:8px}
.stage-count{font-size:10px;color:var(--ink4);margin-top:auto}
.stage-break{width:210px;flex-shrink:0;padding:20px 16px;border-right:1px solid var(--border);background:var(--red-bg)}
.break-eyebrow{display:flex;align-items:center;gap:5px;font-family:'Geist Mono',monospace;font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--red);margin-bottom:8px}
.break-eyebrow::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--red);flex-shrink:0}
.break-text{font-size:12px;color:var(--ink2);line-height:1.5}
.stage-caps{flex:1;padding:14px 16px;min-width:0}
.caps-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:5px}
.cap-pill{display:flex;align-items:center;gap:8px;padding:8px 11px;border:1px solid var(--border);border-radius:8px;background:var(--bg);cursor:pointer;transition:all .12s;min-width:0}
.cap-pill:hover{border-color:var(--border2);background:var(--surface);transform:translateY(-1px)}
.cap-pill.selected{border-color:var(--moat);background:var(--moat-bg)}
.cap-pill.dimmed{opacity:.18;pointer-events:none}
.pill-icon{width:26px;height:26px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:12px}
.pill-text{min-width:0;flex:1}
.pill-name{font-size:12px;font-weight:500;color:var(--ink);line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pill-line{font-size:10px;color:var(--ink3);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px}
.pill-dot{flex-shrink:0;width:6px;height:6px;border-radius:50%;margin-left:2px}
.detail-panel{width:0;flex-shrink:0;overflow:hidden;border-left:1px solid var(--border);background:var(--surface);transition:width .22s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column}
.detail-panel.open{width:340px}
.dp-head{padding:18px 20px 14px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;align-items:flex-start;justify-content:space-between;gap:10px}
.dp-title{font-family:'Instrument Serif',serif;font-size:16px;line-height:1.2;color:var(--ink);letter-spacing:-.01em}
.dp-close{width:24px;height:24px;border:1px solid var(--border2);border-radius:5px;background:none;cursor:pointer;color:var(--ink3);font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .1s}
.dp-close:hover{background:var(--surface2);color:var(--ink)}
.dp-chips{display:flex;gap:5px;padding:12px 20px 0;flex-wrap:wrap;flex-shrink:0}
.dp-chip{font-size:10px;font-weight:500;padding:3px 9px;border-radius:20px;font-family:'Geist Mono',monospace;letter-spacing:.02em}
.chip-revops{background:var(--moat-bg);color:var(--moat);border:1px solid var(--moat-border)}
.chip-cfo{background:var(--diff-bg);color:var(--diff);border:1px solid var(--diff-border)}
.chip-both{background:var(--surface2);color:var(--ink2);border:1px solid var(--border2)}
.dp-body{flex:1;overflow-y:auto}
.dp-body::-webkit-scrollbar{width:3px}
.dp-body::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.dp-section{padding:16px 20px;border-bottom:1px solid var(--border)}
.dp-section:last-child{border-bottom:none}
.dp-sec-lbl{display:flex;align-items:center;gap:6px;font-family:'Geist Mono',monospace;font-size:9px;letter-spacing:.09em;text-transform:uppercase;margin-bottom:10px}
.dp-sec-lbl .dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
.dp-items{display:flex;flex-direction:column;gap:7px}
.dp-item{display:flex;gap:7px;align-items:flex-start}
.dp-dash{font-family:'Geist Mono',monospace;font-size:10px;color:var(--ink4);flex-shrink:0;margin-top:2px}
.dp-text{font-size:12px;color:var(--ink2);line-height:1.5}
.ov-header{margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid var(--border)}
.ov-eyebrow{font-family:'Geist Mono',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink4);margin-bottom:10px}
.ov-title{font-family:'Instrument Serif',serif;font-size:26px;font-weight:400;line-height:1.15;letter-spacing:-.02em;color:var(--ink);margin-bottom:8px}
.ov-title em{font-style:italic;color:var(--moat)}
.ov-body{font-size:13px;color:var(--ink2);line-height:1.7;max-width:580px}
.ov-stages{display:flex;flex-direction:column;gap:7px;margin-bottom:20px}
.ov-row{display:flex;align-items:center;gap:14px;padding:13px 16px;border:1px solid var(--border);border-radius:10px;background:var(--surface);cursor:pointer;transition:all .12s}
.ov-row:hover{border-color:var(--border2);transform:translateX(2px)}
.ov-row.moat{border-left:3px solid var(--moat);background:var(--moat-bg)}
.ov-num{font-family:'Geist Mono',monospace;font-size:10px;color:var(--ink4);width:22px;flex-shrink:0}
.ov-name{font-size:13px;font-weight:500;color:var(--ink);width:170px;flex-shrink:0}
.ov-row.moat .ov-name{color:var(--moat)}
.ov-break{font-size:12px;color:var(--ink3);flex:1;line-height:1.4}
.ov-pills{display:flex;gap:4px;margin-left:auto;flex-shrink:0;flex-wrap:wrap;max-width:200px;justify-content:flex-end}
.ov-pill{font-size:9px;padding:2px 7px;border-radius:20px;background:var(--surface2);color:var(--ink3);border:1px solid var(--border);white-space:nowrap}
.ov-row.moat .ov-pill{background:var(--moat-bg);color:var(--moat);border-color:var(--moat-border)}
.ov-legend{padding:14px 18px;background:var(--surface);border:1px solid var(--border);border-radius:8px}
.ov-leg-title{font-family:'Geist Mono',monospace;font-size:9px;letter-spacing:.09em;text-transform:uppercase;color:var(--ink4);margin-bottom:10px}
.ov-leg-items{display:flex;gap:18px;flex-wrap:wrap}
.ov-leg-item{display:flex;align-items:center;gap:7px;font-size:11px;color:var(--ink3)}
.ov-leg-sw{width:10px;height:10px;border-radius:2px}
.statusbar{height:30px;background:var(--surface);border-top:1px solid var(--border);display:flex;align-items:center;padding:0 24px;gap:16px;flex-shrink:0}
.sb-s{font-family:'Geist Mono',monospace;font-size:9px;letter-spacing:.06em;color:var(--ink4);text-transform:uppercase}
.sb-s span{color:var(--ink3)}
</style>
</head>
<body>
<div class="app">
<div class="topbar">
  <div class="t-left">
    <button class="toggle-btn" onclick="toggleSB()"><div class="hlines"><span></span><span></span><span></span></div></button>
    <div class="brand">MonetizeNow <span>/ Product Intelligence</span></div>
  </div>
  <div class="t-right">
    <button class="ptab on" onclick="setP('all',this)">All</button>
    <button class="ptab" onclick="setP('revops',this)">VP RevOps</button>
    <button class="ptab" onclick="setP('cfo',this)">CFO</button>
  </div>
</div>
<div class="legend-bar">
  <div class="leg"><span class="leg-mark" style="background:var(--moat);border-radius:50%"></span>Architectural moat</div>
  <div class="leg"><span class="leg-mark" style="background:var(--diff)"></span>Differentiator</div>
  <div class="leg"><span class="leg-mark" style="background:var(--ink5)"></span>Core</div>
  <div class="leg-sep"></div>
  <div class="leg"><span class="leg-mark" style="background:#fee2e2;border:1px solid #fca5a5"></span>The break — what fails today</div>
  <div class="leg-sep"></div>
  <div class="leg" style="color:var(--ink4);font-size:10px;margin-left:auto">Click any capability for full detail →</div>
</div>
<div class="main">
  <nav class="sidebar" id="sidebar">
    <div class="sb-scroll">
      <div class="sb-item on" onclick="go('overview',this)"><span class="sb-pip" style="background:var(--ink3)"></span>Overview</div>
      <div class="sb-group">Journey</div>
      <div class="sb-item" onclick="go('journey',this)"><span class="sb-pip" style="background:var(--ink3)"></span>Full journey map</div>
      <div class="sb-group">By stage</div>
      <div class="sb-item" onclick="go('orig',this)"><span class="sb-pip" style="background:#a16207"></span>01 · Deal origination</div>
      <div class="sb-item" onclick="go('cpq',this)"><span class="sb-pip" style="background:var(--diff)"></span>02 · Configure Price Quote</div>
      <div class="sb-item" onclick="go('policy',this)"><span class="sb-pip" style="background:var(--moat)"></span>03 · Policy engine</div>
      <div class="sb-item" onclick="go('contract',this)"><span class="sb-pip" style="background:#9a3412"></span>04 · Contract &amp; Renewal</div>
      <div class="sb-item" onclick="go('billing',this)"><span class="sb-pip" style="background:#1e4d8c"></span>05 · Billing Usage Payments</div>
      <div class="sb-item" onclick="go('infra',this)"><span class="sb-pip" style="background:#3d6b24"></span>06 · Automation Integration</div>
      <div class="sb-group">Persona</div>
      <div class="sb-item" onclick="go('overview',this);setP('revops',null)"><span class="sb-pip" style="background:var(--moat)"></span>VP RevOps view</div>
      <div class="sb-item" onclick="go('overview',this);setP('cfo',null)"><span class="sb-pip" style="background:var(--diff)"></span>CFO view</div>
    </div>
  </nav>
  <div class="content-area">
    <div class="content" id="content">
      <div class="sec on" id="sec-overview"><div style="padding:28px 32px 64px">
        <div class="ov-header">
          <div class="ov-eyebrow">Product intelligence brief</div>
          <div class="ov-title">The revenue journey —<br><em>where it breaks, what fixes it</em></div>
          <div class="ov-body">Six stages. Each one is a point where revenue either flows cleanly or leaks. The red column shows what fails today. Every capability maps to a specific failure at a specific stage. Click any stage to go deep.</div>
        </div>
        <div class="ov-stages" id="ov-stages"></div>
        <div class="ov-legend">
          <div class="ov-leg-title">Reading a capability entry</div>
          <div class="ov-leg-items">
            <div class="ov-leg-item"><span class="ov-leg-sw" style="background:var(--blue-bg);border:1px solid #bfdbfe"></span>Behaviour — what it does</div>
            <div class="ov-leg-item"><span class="ov-leg-sw" style="background:#fff5f5;border:1px solid #fca5a5"></span>Failure addressed — before MN</div>
            <div class="ov-leg-item"><span class="ov-leg-sw" style="background:var(--green-bg);border:1px solid #6ee7b7"></span>Who carries it today</div>
          </div>
        </div>
      </div></div>
      <div class="sec" id="sec-journey"><div style="padding:28px 32px 64px"><div class="journey-map" id="map-all"></div></div></div>
      <div class="sec" id="sec-orig"><div style="padding:28px 32px 64px"><div class="journey-map" id="map-orig"></div></div></div>
      <div class="sec" id="sec-cpq"><div style="padding:28px 32px 64px"><div class="journey-map" id="map-cpq"></div></div></div>
      <div class="sec" id="sec-policy"><div style="padding:28px 32px 64px"><div class="journey-map" id="map-policy"></div></div></div>
      <div class="sec" id="sec-contract"><div style="padding:28px 32px 64px"><div class="journey-map" id="map-contract"></div></div></div>
      <div class="sec" id="sec-billing"><div style="padding:28px 32px 64px"><div class="journey-map" id="map-billing"></div></div></div>
      <div class="sec" id="sec-infra"><div style="padding:28px 32px 64px"><div class="journey-map" id="map-infra"></div></div></div>
    </div>
    <div class="detail-panel" id="dp">
      <div class="dp-head">
        <div class="dp-title" id="dp-title"></div>
        <button class="dp-close" onclick="closeDP()">✕</button>
      </div>
      <div class="dp-chips" id="dp-chips"></div>
      <div class="dp-body" id="dp-body"></div>
    </div>
  </div>
</div>
<div class="statusbar">
  <div class="sb-s">MonetizeNow / Product Intelligence</div>
  <div class="sb-s" id="sb-p" style="margin-left:auto">Viewing: <span>All capabilities</span></div>
  <div class="sb-s" id="sb-sel">Select a capability for detail</div>
</div>
</div>
<script>
var sbOpen=true,activeP='all';
var D=[
  {id:'orig',num:'01',title:'Deal origination',color:'#a16207',colorBg:'#fefce8',
   fracture:'Deals enter as unstructured signals — CRM, email, verbal. No clean handoff. RevOps translates manually on every deal.',
   caps:[
    {name:'Salesforce connector',line:'Bidirectional sync with status write-back on close',tag:'core',persona:'revops',
     what:['Opportunity ingested with customId, owner, accountId, direct URL reference','PROCESSED state writes WON back to Salesforce automatically','Net-new accounts created in MN with external ID for reverse lookup'],
     prob:['RevOps manually monitors CRM to intercept bad-data deals before billing','Deals close in Salesforce with zero billing awareness — invoiced late, wrong, or missed','Systems diverge; weekly 2–4hr reconciliation with no automated correction path'],
     feel:['RevOps: the CRM-to-billing translation job is replaced by a sync','Sales ops: pipeline and revenue data reference the same records','CFO: won-but-not-billed becomes a detectable state, not a silent leak']},
    {name:'Deal Room',line:'Persistent shared workspace; all versions timestamped in platform',tag:'diff',persona:'revops',
     what:['All activity — versions, counterproposals, commitments — recorded with timestamps','Buyer participates in-platform; no PDF circulation or email thread dependency','Every deal version traceable; no ambiguity about which was accepted'],
     prob:['Deals accumulate 4–7 PDFs by close; disputed versions require forensic reconstruction','Verbal commitments during negotiation surface as billing disputes post-signature','Post-signature disagreements have no clean record — inbox archaeology across both parties'],
     feel:['RevOps: billing disputes resolved against a platform record, not memory','Legal: informal commitments are either in the record or they did not happen','CFO: off-contract commitments that become billing exceptions stop occurring']},
    {name:'Multi-quote opportunities',line:'One opportunity, multiple quotes, full version history retained',tag:'core',persona:'revops',
     what:['Multiple quotes per opportunity with primaryQuoteId; all versions retained permanently','Types: NEW, AMENDMENT, RENEWAL — each with own workflow and data requirements','No quote deleted when superseded by a revision'],
     prob:['Reps clone opportunities per revision — pipeline becomes structurally unanalysable','No scenario comparison for same deal without an external spreadsheet','Post-close decision trail — what was offered, countered, chosen — is unrecoverable'],
     feel:['RevOps: deal history contained in one record — auditable and complete','Sales leadership: pricing strategy analysis becomes possible from structured data','CFO: deal structure decisions are on record and attributable']}
  ]},
  {id:'cpq',num:'02',title:'Configure · Price · Quote',color:'#0d6b52',colorBg:'#f0fdf9',
   fracture:'Reps build quotes from memory. Wrong products, wrong prices, wrong terms. RevOps corrects 60–70% of quotes before deals can advance.',
   caps:[
    {name:'Guided quoting',line:'Invalid configurations structurally unavailable, not just warned',tag:'diff',persona:'revops',
     what:['Catalog filtered to valid combinations at selection time — incompatible products not surfaced','Pricing rules applied at selection; rep sees rule-adjusted price, not base price','Configuration validated before save — errors prevented, not warned'],
     prob:['Incompatible selections reach contract stage and require retraction after signing','Discount applied to wrong tier — shortfall found at invoice, weeks post-close','RevOps reviews 60–70% of quotes for structural errors — recurring overhead'],
     feel:['RevOps: quote review for basic errors ceases to be necessary — the task disappears','Reps: quote construction faster — only valid paths available','CFO: pricing integrity established at creation, not corrected at invoice']},
    {name:'Quote blueprints',line:'Pre-approved structures as validated starting points',tag:'diff',persona:'revops',
     what:['Blueprints define validated product sets, discount ranges, standard terms','Reps start from a correct baseline — not from memory or a copied prior quote','Blueprint usage trackable — analytical signal on which structures close deals'],
     prob:['Each rep reconstructs from memory — inconsistency compounds across team','Winning configs are tacit knowledge held by senior reps; lost when they leave','No mechanism to retire outdated structures; old formats circulate as unofficial templates'],
     feel:['Sales leadership: best configurations become institutional property','RevOps: standard deals stop requiring RevOps involvement to be correctly formed','Enablement: onboarding ramp shortens — new reps start from proven structures']},
    {name:'Versioned rate cards',line:'Rate at quote creation immutably locked to that quote',tag:'core',persona:'cfo',
     what:['Every rate has startDate and endDate — pricing history structurally preserved','Rate at quote creation locked; subsequent catalog changes do not affect in-flight deals','Updates propagate consistently; all tenants reference same versioned catalog'],
     prob:['Rate card update bleeds into in-flight contracts — wrong billing at next run','Finance cannot reconstruct the applicable rate on a given date — no version trail','Reps quote outdated rates; customer billed differently than quoted'],
     feel:['CFO: rate disputes at audit closed by data, not discussion','Finance: billing accuracy improves without manual rate reconciliation','RevOps: rate changes do not require notifying every rep']},
    {name:'Multi-model pricing',line:'Flat, per-seat, usage, hybrid — all native, no re-platform required',tag:'diff',persona:'cfo',
     what:['Offering V2 API supports new pricing types as configuration, not engineering','All models coexist on one contract — platform fee + per-seat + usage on single invoice','Tiered, volume, and flat structures native — not billing workarounds'],
     prob:['Move to hybrid pricing — vendor cannot support it — 9-month re-platform required','Multiple models require multiple systems; unified invoice is structurally impossible','Sales cannot offer market-appropriate structures because billing imposes constraints'],
     feel:['CFO: pricing strategy evolves without triggering an infrastructure project','Product: pricing decisions driven by market fit, not billing architecture','Sales: hybrid structures available to close now, not after re-platform']},
    {name:'Quote types',line:'NEW / AMENDMENT / RENEWAL with own workflows and contract lineage',tag:'core',persona:'revops',
